{
  "name": "spec-okf",
  "version": "0.1.0",
  "description": "CLI de scaffolding para Spec-Driven Development + Open Knowledge Format (OKF), compartilhando contexto .md/.yaml entre Claude, Codex, Cursor, Gemini, Copilot e Windsurf.",
  "type": "module",
  "bin": {
    "spec-okf": "dist/cli.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "tsup"
  },
  "keywords": [
    "spec-driven",
    "spec-driven-development",
    "sdd",
    "okf",
    "open-knowledge-format",
    "scaffolding",
    "claude",
    "codex",
    "cursor",
    "ai-agents"
  ],
  "author": "Giovanni Della Dea",
  "license": "MIT",
  "packageManager": "pnpm@11.4.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/giossaurus/spec-okf.git"
  },
  "bugs": {
    "url": "https://github.com/giossaurus/spec-okf/issues"
  },
  "homepage": "https://github.com/giossaurus/spec-okf#readme",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "commander": "^12.1.0",
    "picocolors": "^1.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0"
  }
}
